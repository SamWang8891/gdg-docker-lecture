# =====================================
# Debian + apt 版本
# =====================================
# 重點：
#   1. DEBIAN_FRONTEND=noninteractive 避免被互動式問題卡住
#   2. update + install + clean 要在同一個 RUN 裡（避免 cache 陷阱）
#   3. --no-install-recommends 不裝建議套件，省空間
#   4. rm -rf /var/lib/apt/lists/* 清掉 apt 快取
# =====================================
FROM debian:bookworm-slim

# 環境變數：避免 apt 互動式提問（例如裝 tzdata 會問時區）
ENV DEBIAN_FRONTEND=noninteractive

# 注意 \ 的位置，shell 換行語法
# && 把多個指令串成一個 RUN，產生一個 layer
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
         ca-certificates \
        php-cli \
        php-curl \
        php-mbstring \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY script.php .

CMD ["php", "script.php"]
